# ==============================================================================
# Python Data Analysis .gitignore Template
# ==============================================================================

# --- Python Build & Runtime Cache ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual Environments ---
.venv/
venv/
ENV/
env/
conda-env/
pip-selfcheck.json

# --- Jupyter Notebooks & IPython ---
.ipynb_checkpoints
*/.ipynb_checkpoints/*
.ipython/
profile_default/
ipython_config.py

# --- Data & Datasets (Avoid committing heavy files to git) ---
*.csv
*.tsv
*.xlsx
*.xls
*.json
*.parquet
*.feather
*.h5
*.hd5
*.hdf5
*.pkl
*.pickle
*.npy
*.npz
*.sqlite
*.db

# Common Data Directories
data/
raw_data/
processed_data/
datasets/
inputs/
outputs/
models/     # For trained machine learning models (often very large)

# Exceptions: If you want to keep the directory structure in Git,
# you can add a .gitkeep file inside the folder and un-ignore it:
# !data/.gitkeep
# !data/raw/.gitkeep
# !data/processed/.gitkeep

# --- Environment Variables & Credentials ---
.env
.env.*
.secrets
secrets.*
credentials.json
*.pem
*.key

# --- IDEs & Editors ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.project
.pydevproject
.settings/

# --- Operating System Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Logs & Testing ---
*.log
logs/
.pytest_cache/
.tox/
.coverage
htmlcov/

# --- Hidden Files and Folders (Starting with .) ---
.*
!.gitignore
!**/.gitkeep
!**/.streamlit/
!**/.streamlit/**
!naver-api-app/data/

# Streamlit secrets (Credentials)
**/.streamlit/secrets.toml



